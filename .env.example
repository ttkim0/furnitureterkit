# Copy this file to .env (which is gitignored) and fill in your values.
#
#   cp .env.example .env
#   # then edit .env and paste your key
#
# Restart the API server (Ctrl-C the dev:server terminal and re-run, or just
# `kill $(lsof -ti:3001)` — node --watch will reload on its own when this
# file changes only if the server file changes too, so a manual restart is
# safest after editing .env).

# Required for free-form generation and image-reference generation.
# Without this, the server falls back to keyword templates and ignores images.
# Get one at https://console.anthropic.com → Settings → API Keys.
ANTHROPIC_API_KEY=sk-ant-paste-your-key-here

# Required for PHOTOREAL image-to-mesh generation (Hunyuan3D via Fal.ai).
# Without this, image references go to Claude (which writes SCAD code) — that
# can produce recognizable shapes but never matches a photo's exact silhouette.
# With this set, an uploaded image + Max Quality routes to Hunyuan3D Pro,
# which is what CADAM's "creative mode" uses (~$0.20–$0.40/job, 30s–3min).
# Get one at https://fal.ai → Settings → API Keys.
FAL_KEY=paste-your-fal-key-here

# Optional but recommended for TEXT-ONLY prompts and IMAGE+TEXT prompts.
# - Text-only: OpenAI generates a studio reference image, then Hunyuan3D meshes it.
# - Image+text: OpenAI edits your reference to incorporate the text changes
#   ("but with leather", "but one more seat") before meshing.
# Without this, text-only prompts fall back to Claude SCAD (much lower quality).
# Uses gpt-image-1 (~$0.04/image at medium quality).
# Get one at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-paste-your-openai-key-here

# Optional: override the API server port (defaults to 3001).
# PORT=3001

# ─── Frontend env (Vite reads VITE_* at build time) ──────────────────────
# Supabase backend for landing-page sign-in. The URL is the project URL from
# https://supabase.com/dashboard → Project Settings → API.
# The anon key is the "anon public" key on that same page (safe for browser).
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGc...your-anon-key
