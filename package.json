    "@react-three/fiber": "^9.0.0",
    "@supabase/supabase-js": "^2.105.4",
    "manifold-3d": "^3.4.1",
    "openai": "^6.37.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.15.1",
    "three": "^0.169.0",
    "undici": "^8.3.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/three": "^0.169.0",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.2.1",
